{
  "uid": "attacker-intel",
  "title": "HoneyMind — Attacker Intelligence",
  "description": "GeoIP, anonymisation, profil attaquant, HASSH, bot/human, AI agents, sophistication",
  "tags": [
    "honeymind",
    "attribution"
  ],
  "timezone": "browser",
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "type": "geomap",
      "title": "Carte mondiale des attaques",
      "gridPos": {
        "h": 10,
        "w": 16,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "view": {
          "id": "zero",
          "lat": 30,
          "lon": 0,
          "zoom": 1
        },
        "controls": {
          "showZoom": true,
          "mouseWheelZoom": true
        },
        "layers": [
          {
            "type": "heatmap",
            "config": {
              "weight": {
                "fixed": 1,
                "max": 100,
                "min": 0,
                "mode": "fixed"
              },
              "radius": 25,
              "blur": 15
            },
            "location": {
              "mode": "lookup",
              "lookupField": "country_code",
              "gazetteer": "public/gazetteer/countries.json"
            },
            "name": "Attacks"
          }
        ]
      },
      "targets": [
        {
          "expr": "sum by (country_code, country) (honeymind_country_events_total)",
          "legendFormat": "{{country}}",
          "refId": "A",
          "instant": false
        }
      ]
    },
    {
      "id": 2,
      "type": "table",
      "title": "Top Pays",
      "gridPos": {
        "h": 10,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "sortBy": [
          {
            "displayName": "Value",
            "desc": true
          }
        ]
      },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Events"
              },
              {
                "id": "custom.displayMode",
                "value": "lcd-gauge"
              },
              {
                "id": "color",
                "value": {
                  "mode": "continuous-RdYlGr"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "sort_desc(sum by (country_code, country) (honeymind_country_events_total))",
          "legendFormat": "{{country_code}} {{country}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ]
    },
    {
      "id": 10,
      "type": "piechart",
      "title": "Type d'anonymisation",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "pieType": "donut",
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        }
      },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "tor"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#F2495C",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "vpn_commercial"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#FF780A",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "datacenter"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#8AB8FF",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "residential"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#73BF69",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum by (anon_type) (honeymind_anonymization_type_total)",
          "legendFormat": "{{anon_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Nœuds Tor",
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 6,
        "y": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "dark-red",
                "value": 1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"honeymind\", is_tor=\"true\"} [$__range]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "type": "stat",
