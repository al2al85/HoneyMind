                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum by (profile_type) (honeymind_profile_type_total)",
          "legendFormat": "{{profile_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 21,
      "type": "histogram",
      "title": "Score de sophistication (0-10)",
      "gridPos": {
        "h": 8,
        "w": 9,
        "x": 7,
        "y": 18
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "bucketOffset": 0,
        "fillOpacity": 80,
        "legend": {
          "displayMode": "hidden"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(honeymind_sophistication_score_bucket[$__rate_interval])) by (le)",
          "legendFormat": "{{le}}",
          "refId": "A",
          "format": "heatmap"
        }
      ]
    },
    {
      "id": 22,
      "type": "barchart",
      "title": "Outils détectés",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 18
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "orientation": "horizontal",
        "legend": {
          "displayMode": "hidden"
        }
      },
      "targets": [
        {
          "expr": "sort_desc(sum by (tool) (honeymind_tool_detections_total))",
          "legendFormat": "{{tool}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ]
    },
    {
      "id": 30,
      "type": "table",
      "title": "HASSH — Empreintes SSH clients",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 26
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "sortBy": [
          {
            "displayName": "Value",
            "desc": true
          }
        ]
      },
      "targets": [
        {
          "expr": "sort_desc(sum by (ssh_client) (honeymind_hassh_detections_total))",
          "legendFormat": "{{ssh_client}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ]
    },
    {
      "id": 31,
      "type": "table",
      "title": "ISP / ASN",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 26
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "sortBy": [
          {
            "displayName": "Count",
            "desc": true
          }
        ]
      },
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "labels"
          }
        },
        {
          "id": "groupBy",
          "options": {
            "fields": {
              "isp": {
                "aggregations": [
                  "count"
                ],
                "operation": "groupby"
              },
              "asn": {
                "aggregations": [
                  "lastNotNull"
                ],
                "operation": "groupby"
              },
              "country": {
                "aggregations": [
                  "lastNotNull"
                ],
                "operation": "groupby"
              },
              "country_code": {
                "aggregations": [
                  "lastNotNull"
                ],
                "operation": "groupby"
              }
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": [
              {
                "desc": true,
                "displayName": "isp Count"
              }
            ]
          }
        }
      ],
      "targets": [
        {
          "expr": "{job=\"honeymind\", event_type=\"session_start\"}",
          "queryType": "range",
          "refId": "A"
        }
      ]
    },
    {
      "id": 40,
      "type": "logs",
      "title": "Agents IA détectés (AI trap triggered)",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 34
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": false
      },
      "targets": [
        {
          "expr": "{job=\"honeymind\", ai_trap=\"true\"} | json | line_format \"[AI AGENT] {{.client_ip}} ({{.country}}) | {{._profile_label}} | trap={{._ai_trap_ids}} | cmd={{.command_raw}}\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 41,
      "type": "logs",
      "title": "Narrative des attaquants (profil)",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 42
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{job=\"honeymind\", event_type=\"session_end\"} | json | _narrative != \"\" | line_format \"{{.client_ip}} | score={{._sophistication_score}}/10 | {{._narrative}}\"",
          "refId": "A"
        }
      ]
    }
  ]
