{
  "uid": "commands-targets",
  "title": "HoneyMind \u2014 Commands, Targets & Credentials",
  "description": "What attackers run, what files they access, credentials they try",
  "tags": [
    "honeymind",
    "commands"
  ],
  "timezone": "browser",
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "type": "heatmap",
      "title": "Command Activity Heatmap (hour \u00d7 day)",
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": {
          "exponent": 0.5,
          "fill": "#F2495C",
          "mode": "scheme",
          "scale": "exponential",
          "scheme": "Oranges",
          "steps": 64
        },
        "legend": {
          "show": true
        },
        "tooltip": {
          "show": true,
          "yHistogram": false
        }
      },
      "targets": [
        {
          "expr": "sum(rate(honeymind_commands_total[$__rate_interval]))",
          "legendFormat": "commands",
          "refId": "A",
          "format": "heatmap"
        }
      ]
    },
    {
      "id": 2,
      "type": "table",
      "title": "Top Commands",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "sortBy": [
          {
            "displayName": "Count",
            "desc": true
          }
        ]
      },
      "transformations": [],
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "topk(30, sum by (command_raw) (count_over_time({job=\"honeymind\", event_type=\"command\"} | json | command_raw != \"\" [$__range])))",
          "queryType": "instant"
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value #A"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Occurrences"
              }
            ]
          }
        ]
      }
    },
    {
      "id": 10,
      "type": "table",
      "title": "Files Accessed",
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 8,
        "h": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "sortBy": [
          {
            "displayName": "Value",
            "desc": true
          }
        ]
      },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value #A"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Occurrences"
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "topk(30, sum by (_file_accessed) (count_over_time({job=\"honeymind\", event_type=\"command\"} | json | _file_accessed != \"\" | _file_accessed != \"null\" [$__range])))",
          "queryType": "instant"
        }
      ],
      "transformations": []
    },
    {
      "id": 11,
      "type": "table",
      "title": "Credentials Attempted",
      "gridPos": {
        "x": 8,
        "y": 10,
        "w": 8,
        "h": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "sortBy": [
          {
            "displayName": "Count",
            "desc": true
          }
        ]
      },
      "transformations": [],
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "topk(30, sum by (client_ip, _auth_username, _auth_password) (count_over_time({job=\"honeymind\", event_type=\"auth_attempt\"} | json | _auth_success = \"false\" [7d])))",
          "queryType": "instant"
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "client_ip"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "IP"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "_auth_username"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Utilisateur"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "_auth_password"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Mot de passe"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value #A"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Tentatives"
              }
            ]
          }
        ]
      }
    },
    {
      "id": 12,
      "type": "table",
      "title": "Top Usernames Tried",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "sortBy": [
          {
            "displayName": "Value",
            "desc": true
          }
        ]
      },
      "targets": [
        {
          "expr": "sort_desc(sum by (username) (honeymind_auth_attempts_total{success=\"false\"}))",
          "legendFormat": "{{username}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ]
    },
    {
      "id": 20,
      "type": "logs",
      "title": "Commands by Category \u2014 EXECUTION",
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": false,
        "dedupStrategy": "exact"
      },
      "targets": [
        {
          "expr": "{job=\"honeymind\", attack_category=\"EXECUTION\"} | json | line_format \"{{.client_ip}} ({{.country}}) | {{.command_raw}}\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 21,
      "type": "logs",
      "title": "Commands by Category \u2014 PERSISTENCE",
      "gridPos": {
        "x": 12,
        "y": 28,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": false,
        "dedupStrategy": "exact"
      },
      "targets": [
        {
          "expr": "{job=\"honeymind\", attack_category=\"PERSISTENCE\"} | json | line_format \"{{.client_ip}} ({{.country}}) | {{.command_raw}}\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 22,
      "type": "logs",
      "title": "Uploaded / Downloaded Files",
      "gridPos": {
        "x": 0,
        "y": 36,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": false
      },
      "targets": [
        {
          "expr": "{job=\"honeymind\"} | json | _uploaded_file != \"\" | _uploaded_file != \"null\"  | line_format \"[UPLOAD] {{.client_ip}} ({{.country}}) | {{._uploaded_file}} | cmd: {{.command_raw}}\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "type": "table",
      "title": "Top Passwords Tried",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 16,
        "y": 10,
        "w": 8,
        "h": 10
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "topk(30, sum by (_auth_password) (count_over_time({job=\"honeymind\", event_type=\"auth_attempt\"} | json | _auth_password != \"\" | _auth_password != \"null\" [$__range])))",
          "queryType": "instant"
        }
      ],
      "transformations": [],
      "options": {
        "sortBy": [
          {
            "displayName": "_auth_password Count",
            "desc": true
          }
        ]
      },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value #A"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Occurrences"
              }
            ]
          }
        ]
      }
    }
  ]
}